{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":15032721,"datasetId":9623088,"databundleVersionId":15911200}],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"import os\nimport numpy as np\nimport torch\nimport torch.nn as nn\nfrom torch.utils.data import Dataset, DataLoader\nfrom skimage.restoration import estimate_sigma\n!pip install deepinv\nimport deepinv as dinv\n!pip install bm3d\nfrom bm3d import bm3d\nimport pandas as pd # data processing, CSV file I/O (e.g. pd.read_csv)\nimport pydicom #To process DICOM files\nimport matplotlib.pyplot as plt #To show the images and create graphics\nimport cv2 as cv\nfrom scipy.io import loadmat\nfrom skimage.metrics import peak_signal_noise_ratio, structural_similarity #PSNR e SSIM metrics to image evaluation\nimport scipy.stats as st","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true,"execution":{"iopub.status.busy":"2026-03-04T13:49:16.675224Z","iopub.execute_input":"2026-03-04T13:49:16.675531Z","iopub.status.idle":"2026-03-04T13:49:35.352315Z","shell.execute_reply.started":"2026-03-04T13:49:16.675504Z","shell.execute_reply":"2026-03-04T13:49:35.351626Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Visualizando uma imagem de mama \nVamos vizualizar uma imagem de mama gerada virtualmente \ncom testes clínicos virtuais.\n","metadata":{}},{"cell_type":"code","source":"def visualize_img(img_1,img_2,p1= (1,99), p2 = (1,99),t1 = \"\",t2 = \"\", invert=False):\n    \"\"\" This function can be used for medical image visualisation. \n    It was made in two steps: Apply window level and invert the image. \n    The window-level parameters can be adjusted according to the \n    visualisation needs \"\"\"\n\n    vmin_1, vmax_1 = np.percentile(img_1, p1)\n    vmin_2, vmax_2 = np.percentile(img_2, p2)\n    \n    img_1 = (img_1 - vmin_1) / (vmax_1 - vmin_1)\n    img_1 = np.clip(img_1, 0, 1)\n\n    img_2 = (img_2 - vmin_2) / (vmax_2 - vmin_2)\n    img_2 = np.clip(img_2, 0, 1)\n\n    if invert:\n        img_1 = 1 - img_1\n        img_2 = 1 - img_2\n\n    fig, axes = plt.subplots(1,2,figsize = (20,20))\n    axes[0].imshow(img_1,vmin = 0, vmax = 1,cmap = 'gray')\n    axes[0].axis('off')\n    axes[0].set_title(t1)\n    \n    axes[1].imshow(img_2,vmin = 0, vmax = 1,cmap = 'gray')\n    axes[1].axis('off')\n    axes[1].set_title(t2)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-04T13:49:35.353825Z","iopub.execute_input":"2026-03-04T13:49:35.354377Z","iopub.status.idle":"2026-03-04T13:49:35.362896Z","shell.execute_reply.started":"2026-03-04T13:49:35.354348Z","shell.execute_reply":"2026-03-04T13:49:35.362268Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"img = np.load(\"/kaggle/input/datasets/dyegoalvesp/icmc-course/img_0.npy\") #renomear para a img_0.npy no seu banco na kaggle\nimg_noisy = np.load(\"/kaggle/input/datasets/dyegoalvesp/icmc-course/img_0_noisy.npy\") #renomear para a img_0_noisy.npy no seu banco na kaggle\n\nfig, axes = plt.subplots(1,2,figsize = (15,20))\naxes[0].imshow(img[500:3575,2300:3328],vmin = 100, vmax = 300,cmap = 'gray')\naxes[0].axis('off')\naxes[0].set_title(\"Imagem Virtual de mama sem ruído\")\n    \naxes[1].imshow(img_noisy[500:3575,2300:3328],vmin = 100, vmax = 500,cmap = 'gray')\naxes[1].axis('off')\naxes[1].set_title(\"Imagem Virtual de mama com ruído\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-04T13:49:35.3